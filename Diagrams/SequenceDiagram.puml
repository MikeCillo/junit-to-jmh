@startuml
title Sequence Diagram - ju2jmh Full Conversion Flow
autonumber

actor User
participant "Converter" as C
participant "InputClassRepository" as R
participant "Benchmark Factory / Builder" as F
participant "File System" as FS

User -> C : main(args)
activate C
C -> C : setLanguageLevel(JAVA_17)
C -> C : call()
note right of C: JML @requires outputPath exists

' Inizializzazione Repository Condiviso
C -> R : new InputClassRepository(sourcePath, classPath)
activate R
R --> C : repository instance
deactivate R

alt --ju-runner-benchmark
    C -> C : generateJUBenchmarks()
    C -> F : new WrapperBenchmarkFactory(repository)
    note right of C: [Includes Fail-Fast Method Validation]
else --tailored-benchmark
    C -> C : generateTailoredBenchmarks()
    C -> F : [Uses TailoredBenchmarkFactory]
else default
    C -> C : generateNestedBenchmarks()
    C -> F : new NestedBenchmarkSuiteBuilder(repository)
end

loop For each target class
    C -> F : create / build benchmark
    activate F
    note right of F: e.g. WrapperBenchmarkFactory\n(JML @requires className != null)

    ' Ast & Bytecode Fetching
    F -> R : findClass(className)
    activate R
    note right of R: JML protected
    R -> FS : Read .class and .java files
    R -> R : Parse Bytecode (BCEL)\nParse AST (JavaParser)
    R --> F : InputClass
    deactivate R

    ' Model Generation
    F -> F : filterAndGenerate(methods)
    F --> C : CompilationUnit (New Benchmark AST)
    deactivate F

    ' Output & Conflict Resolution Phase
    C -> C : writeSourceCodeToFile(compilationUnit)
    activate C
    C -> FS : check if exists()
    alt File does not exist / Overwrite
        C -> FS : Write to file
    else Merge
        C -> FS : Read existing file
        C -> C : mergeMethods(existing, new)
        note right of C: JML protected merge
        C -> FS : Write merged AST
    end
    deactivate C
end

deactivate C
@enduml